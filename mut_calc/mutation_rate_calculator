"""
mutation_rate_calculator.py
---------------------------
Core functionality for:
1. Parsing FASTA files
2. Performing Needleman-Wunsch alignment
3. Computing mutation rates
"""

from pathlib import Path
from dataclasses import dataclass
from typing import Dict, Tuple, List
import numpy as np


@dataclass
class MutationResult:
    """Stores mutation statistics for one sequence comparison."""
    query_id: str
    alignment_length: int
    matches: int
    mismatches: int
    mutation_rate: float


def parse_fasta(filepath: str) -> Dict[str, str]:
    """
    Parse a FASTA file into a dictionary.

    Args:
        filepath (str): Path to FASTA file

    Returns:
        Dict[str, str]: header -> sequence
    """
    path = Path(filepath)

    if not path.exists():
        raise FileNotFoundError(f"File not found: {filepath}")

    sequences: Dict[str, str] = {}
    header: str = ""
    seq_parts: List[str] = []

    with open(path, "r") as file:
        for line in file:
            line = line.strip()
            if not line:
                continue

            if line.startswith(">"):
                if header:
                    sequences[header] = "".join(seq_parts)
                header = line[1:]
                seq_parts = []
            else:
                seq_parts.append(line)

    if header:
        sequences[header] = "".join(seq_parts)

    if not sequences:
        raise ValueError("No sequences found in FASTA file.")

    return sequences


def needleman_wunsch(seq1: str, seq2: str) -> Tuple[str, str]:
    """
    Perform global alignment using Needleman-Wunsch.

    Args:
        seq1 (str): reference sequence
        seq2 (str): query sequence

    Returns:
        Tuple[str, str]: aligned sequences
    """
    match, mismatch, gap = 1, -1, -2
    n, m = len(seq1), len(seq2)

    dp = np.zeros((n + 1, m + 1), dtype=int)

    for i in range(n + 1):
        dp[i][0] = i * gap
    for j in range(m + 1):
        dp[0][j] = j * gap

    for i in range(1, n + 1):
        for j in range(1, m + 1):
            diag = dp[i-1][j-1] + (match if seq1[i-1] == seq2[j-1] else mismatch)
            delete = dp[i-1][j] + gap
            insert = dp[i][j-1] + gap
            dp[i][j] = max(diag, delete, insert)

    aligned1, aligned2 = [], []
    i, j = n, m

    while i > 0 or j > 0:
        if i > 0 and j > 0:
            score = match if seq1[i-1] == seq2[j-1] else mismatch
            if dp[i][j] == dp[i-1][j-1] + score:
                aligned1.append(seq1[i-1])
                aligned2.append(seq2[j-1])
                i -= 1
                j -= 1
            elif dp[i][j] == dp[i-1][j] + gap:
                aligned1.append(seq1[i-1])
                aligned2.append("-")
                i -= 1
            else:
                aligned1.append("-")
                aligned2.append(seq2[j-1])
                j -= 1
        elif i > 0:
            aligned1.append(seq1[i-1])
            aligned2.append("-")
            i -= 1
        else:
            aligned1.append("-")
            aligned2.append(seq2[j-1])
            j -= 1

    return "".join(reversed(aligned1)), "".join(reversed(aligned2))


def calculate_mutation_rate(ref: str, query: str) -> Tuple[int, int, int, float]:
    """
    Compute mutation statistics from aligned sequences.

    Args:
        ref (str): aligned reference
        query (str): aligned query

    Returns:
        Tuple[int, int, int, float]:
            alignment_length, matches, mismatches, mutation_rate
    """
    length = len(ref)
    matches = sum(r == q for r, q in zip(ref, query))
    mismatches = length - matches
    rate = mismatches / length if length > 0 else 0.0

    return length, matches, mismatches, round(rate, 6)
